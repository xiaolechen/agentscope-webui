# AgentScope Web UI — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── Required ──────────────────────────────────────────────────────────────────

# JWT signing secret. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If unset, a random secret is generated at startup (all sessions break on restart).
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ── Auth ──────────────────────────────────────────────────────────────────────

# Admin account password (default: admin123 — change before production use)
# ADMIN_PASSWORD=your-secure-password

# ── Ports ─────────────────────────────────────────────────────────────────────

# Backend API port (default: 8000)
# BACKEND_PORT=8000

# Frontend dev server port (default: 5173)
# FRONTEND_PORT=5173

# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis host (default: localhost)
# REDIS_HOST=localhost

# Redis port (default: 6379)
# REDIS_PORT=6379

# ── Optional integrations ─────────────────────────────────────────────────────

# AMap (高德) MCP server API key — enables map tools for agents
# AMAP_API_KEY=your-amap-key

# ── Python package mirror ──────────────────────────────────────────────────────
# Set this if PyPI is slow or unreachable (e.g. in China or restricted networks).
# setup.sh reads this value and passes it to uv automatically.
#
# Common mirrors:
#   阿里云:  https://mirrors.aliyun.com/pypi/simple/
#   清华大学: https://pypi.tuna.tsinghua.edu.cn/simple/
#   腾讯云:  https://mirrors.cloud.tencent.com/pypi/simple/
# UV_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
