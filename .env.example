# AgentScope Web UI — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── Required ──────────────────────────────────────────────────────────────────

# JWT signing secret. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If unset, a random secret is generated at startup (all sessions break on restart).
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ── Auth ──────────────────────────────────────────────────────────────────────

# Admin account password (default: admin123 — change before production use)
# ADMIN_PASSWORD=your-secure-password

# ── Ports ─────────────────────────────────────────────────────────────────────

# Backend API port (default: 8000)
# BACKEND_PORT=8000

# Backend bind host (default: 127.0.0.1 — loopback only).
# agentscope native endpoints are JWT-gated, but loopback is the safe default.
# Set to 0.0.0.0 ONLY behind a reverse proxy that terminates auth, or for
# remote/sandbox dev where the port is proxied externally.
# BACKEND_HOST=127.0.0.1

# ── Production security ────────────────────────────────────────────────────────

# Enable production security restrictions (default: false — dev/local).
# When true:
#   - Agent Bash tool is restricted to read-only commands (ls/cat/git status).
#     Commands like ip a / curl / ifconfig / rm are denied (PermissionMode.EXPLORE).
#   - stdio MCP injection is blocked; only remote (sse/streamable-http) MCPs run.
#   - stdio MCP registration returns 403.
 PRODUCTION_MODE=true

# PermissionMode applied to agent sessions when PRODUCTION_MODE=true.
#   explore      — read-only only; blocks all writes and network commands (recommended)
#   accept_edits — allows file reads/writes inside workspace directory; ip a still allowed
# PRODUCTION_PERMISSION_MODE=explore

# Trust the X-Forwarded-For header for login rate-limiting (default: false).
# Enable ONLY when the backend is behind a reverse proxy that strips and
# re-adds X-Forwarded-For — otherwise clients can spoof their IP to bypass
# the rate limit. Requires BACKEND_HOST=0.0.0.0 (proxy deployment).
# TRUSTED_PROXY=false

# Frontend dev server port (default: 5173)
# FRONTEND_PORT=5173

# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis host (default: localhost)
# REDIS_HOST=localhost

# Redis port (default: 6379)
# REDIS_PORT=6379

# ── Python package mirror ──────────────────────────────────────────────────────
# Set this if PyPI is slow or unreachable (e.g. in China or restricted networks).
# setup.sh reads this value and passes it to uv automatically.
#
# Common mirrors:
#   阿里云:  https://mirrors.aliyun.com/pypi/simple/
#   清华大学: https://pypi.tuna.tsinghua.edu.cn/simple/
#   腾讯云:  https://mirrors.cloud.tencent.com/pypi/simple/
# UV_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
